root = true

[*.py]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 88

[*.{md,markdown,toml,yaml,yml,json,html,css,js,sh,txt,ini,cfg}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 88

[Makefile]
indent_style = tab
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

